DirectoryIndex index.php

# Désactive MultiViews pour éviter les résolutions inattendues
<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    # Requis par les règles de réécriture si FollowSymLinks est désactivé globalement
    Options +SymLinksIfOwnerMatch

    RewriteEngine On

    # Détecte automatiquement la base (utile si projet en sous-dossier)
    RewriteCond %{REQUEST_URI}::$0 ^(/.+)/(.*)::\2$
    RewriteRule .* - [E=BASE:%1]

    # Préserve l’en-tête Authorization pour Symfony
    RewriteCond %{HTTP:Authorization} .+
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%0]

    # Évite le contenu dupliqué /index.php
    RewriteCond %{ENV:REDIRECT_STATUS} =""
    RewriteRule ^index\.php(?:/(.*)|$) %{ENV:BASE}/$1 [R=308,L]

    # Si le fichier demandé existe, on le sert. Sinon, on passe à index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ %{ENV:BASE}/index.php [L]
</IfModule>

<IfModule !mod_rewrite.c>
  <IfModule mod_alias.c>
    # Fallback propre si mod_rewrite est indisponible
    RedirectMatch 307 ^/$ /index.php/
  </IfModule>
</IfModule>
