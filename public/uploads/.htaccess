# Empêche l’exécution de scripts
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
RemoveType   .php .phtml .php3 .php4 .php5 .php7 .php8

<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phar|pl|py|jsp|asp|sh|cgi)$">
  Require all denied
</FilesMatch>

# Empêche le listing du dossier
Options -Indexes
