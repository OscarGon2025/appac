{# ------- MOBILE / TABLET (< lg) ------- #}
<header class="site-header bg-warning small d-lg-none">
    <div class="container py-1">

        <div class="site-header-row d-flex align-items-center">

            <div class="site-header-scroll d-flex align-items-center flex-nowrap overflow-auto me-2">
        <span class="chip d-inline-flex align-items-center">
          <i class="custom-icon bi-geo-alt me-2 fs-5"></i>
          <strong class="text-dark">Arzal</strong>
        </span>

                {% if header.weather %}
                    <span class="chip chip--temp"><i class="bi bi-thermometer-half me-1"></i>{{ header.weather.temp }}°C</span>
                    <span class="chip chip--wind">
            <i class="bi bi-wind me-1"></i>{{ header.weather.wind }} km/h
            {% if header.weather.dir is not null %}
                <span class="chip--winddir">({{ header.weather.dir }}°)</span>
            {% endif %}
          </span>
                {% endif %}

                {% if header.tide %}
                    <span class="chip chip--tide">
            <i class="bi bi-water me-1"></i>
            <span class="d-none d-sm-inline">Marée :</span>
            <strong class="ms-1">{{ header.tide.type }}</strong>
            <span class="ms-1">{{ header.tide.time|date('H:i') }}</span>
          </span>
                {% endif %}
            </div>


            <a class="btn btn-sm btn-outline-dark site-header-cta"
               href="https://passeportecluse-arzal-camoel.com/"
               target="_blank" rel="noopener" title="Voir horaires des écluses">
                <i class="bi bi-clock-history me-1"></i>
                <span class="btn-text">Horaires des écluses</span>
            </a>
        </div>

    </div>
</header>
