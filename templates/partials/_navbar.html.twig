{# Recibe una variable booleana "transparent" para el modo hero #}
{% set transparent = transparent is defined ? transparent : false %}

<nav class="navbar navbar-expand-lg festava-navbar
            {{ transparent ? 'is-transparent position-absolute top-0 start-0 w-100' : '' }}">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">Site des Plaisanciers</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav align-items-lg-center ms-auto me-lg-5">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#about">Qui sommes-nous ?</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#actus">Actus</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_event_index') }}">Événements</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#partenaires">Partenaires</a></li>
            </ul>

            {% if app.user %}
                <div class="d-flex gap-2">
                    <a href="{{ path('app_account') }}" class="btn btn-outline-dark">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="btn custom-btn">Déconnexion</a>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn custom-btn">Connexion</a>
            {% endif %}
        </div>
    </div>
</nav>
