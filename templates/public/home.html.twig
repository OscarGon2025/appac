{# templates/public/home.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Association des Plaisanciers d'Arzal{% endblock %}

{% block body %}


    {#  Heeader pour Api Meteo, ecluses et marees #}
{#    <header class="site-header">#}
{#        <div class="container">#}
{#            <div class="row">#}
{#                <div class="col-lg-12 col-12 d-flex flex-wrap">#}
{#                    <p class="d-flex me-4 mb-0">#}
{#                        <i class="bi-person custom-icon me-2"></i>#}
{#                        <strong class="text-dark">Bienvenue sur le site de l'Association des Plaisanciers d'Arzal</strong>#}
{#                    </p>#}
{#                </div>#}
{#            </div>#}
{#        </div>#}
{#    </header>#}


    {# --- Hero con vídeo --- #}
    <section class="hero-section" id="section_1">
        <div class="section-overlay"></div>
        <div class="container d-flex justify-content-center align-items-center">
            <div class="row">
                <div class="col-12 mt-auto mb-5 text-center">
                    <small>ASSOCIATION DES PLAISANCIERS D'ARZAL</small>
                    <h1 class="text-white mb-5">Bienvenue sur notre site !</h1>
                    <a class="btn custom-btn smoothscroll" href="#about">Découvrir</a>
                </div>

                <div class="col-lg-12 col-12 mt-auto d-flex flex-column flex-lg-row text-center">
                    <div class="date-wrap">
                        <h5 class="text-white"><i class="custom-icon bi-clock me-2"></i>Prochain événement : 12 Octobre 2025</h5>
                    </div>
                    <div class="location-wrap mx-auto py-3 py-lg-0">
                        <h5 class="text-white"><i class="custom-icon bi-geo-alt me-2"></i>Port de plaisance d'Arzal dans le Morbihan</h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="video-wrap">
            <video autoplay loop muted class="custom-video" poster="">
                <source src="{{ asset('video/istockphoto-1293944549-640_adpp_is.mp4') }}" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    </section>

    {# --- Qui sommes-nous ? --- #}
    <section id="about" class="about-section section-padding text-white">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-8 col-lg-9">
                    <div class="text-center mb-4">
                        <h2 class="display-6 fw-bold mb-3">Qui sommes-nous&nbsp;?</h2>
                        <p class="lead opacity-75 mb-0">
                            Ami(e)s plaisanciers du Port d’Arzal-Camoel, bienvenue sur le site de l’association <strong>APPAC</strong>.
                        </p>
                    </div>

                    <hr class="border-light opacity-25 my-4">

                    <div class="fs-5 opacity-85">
                        <p class="mb-3">…Laissez naviguer votre curiosité à la découverte&nbsp;:</p>
                        <ul class="list-unstyled ps-0 mb-4">
                            <li class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-life-preserver"></i>
                                <span>Nos engagements et les démarches pour la défense des intérêts des plaisanciers</span>
                            </li>
                            <li class="d-flex align-items-start gap-2">
                                <i class="bi bi-emoji-smile"></i>
                                <span>Nos activités festives et diverses autour du plaisir de la pratique de la plaisance</span>
                            </li>
                        </ul>

                        <p class="mb-1">
                            Alors, <em>Cap sur «&nbsp;Qui sommes-nous&nbsp;? / Présentation de l’APPAC&nbsp;»</em> et, si vous appréciez aussi la convivialité,
                            <strong>n’hésitez donc pas à nous rejoindre&nbsp;!</strong>
                        </p>
                        <p class="mb-4">À bientôt&nbsp;⛵</p>
                    </div>


    {# Début Section actus #}

                    <div class="text-center">
                        <a href="{{ path('app_home') }}#actus" class="btn custom-btn px-4">Découvrir nos actus</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# --- Actus --- #}

    <section id="actus" class="news-section section-padding">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center"><h2 class="mb-4">Derniers articles</h2></div>

                {% for a in actus %}
                    <div class="col-lg-4 col-md-6 mb-4">
                        <article class="custom-block-wrap h-100">
                            {% if a.cover %}
                                <img src="{{ asset('uploads/covers/' ~ a.cover) }}" class="custom-block-image img-fluid" alt="{{ a.title }}">
                            {% endif %}
                            <div class="custom-block">
                                <h3 class="h5">
                                    <a href="{{ path('actus_show', { slug: a.slug }) }}" class="custom-btn">{{ a.title }}</a>
                                    {% if a.pinned %}<span class="badge text-bg-warning ms-1">À la une</span>{% endif %}
                                    {% if a.isMembersOnly %}<span class="badge text-bg-secondary ms-1">Membres</span>{% endif %}
                                </h3>
                                <p class="text-muted mb-2">{{ a.publishedAt ? a.publishedAt|date('d/m/Y H:i') : '' }}</p>
                                {% set excerpt = a.content|striptags %}
                                <p class="mb-3">{{ excerpt|length > 160 ? excerpt|slice(0,160) ~ '…' : excerpt }}</p>
                                <a class="btn custom-btn" href="{{ path('actus_show', { slug: a.slug }) }}">Lire</a>
                            </div>
                        </article>
                    </div>
                {% else %}
                    <div class="col-12 text-center"><p>Aucun article pour le moment.</p></div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# Fin Section actus #}



     {# Début Section Events #}

    {# --- Événements --- #}

    <section id="events-section" class="section-padding bg-light">
        <div class="container">
            <div class="row mb-5">
                <div class="col-12 text-center">
                    <h2 class="mb-3">Prochains événements</h2>
                    <p class="text-muted">Découvrez nos sorties et activités à venir</p>
                </div>
            </div>

            <div class="row">
                {% for event in events %}
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">{{ event.title }}</h5>
                                <p class="card-text mb-1">
                                    <strong>Date :</strong> {{ event.startAt|date('d/m/Y H:i') }}
                                    {% if event.endAt %}- {{ event.endAt|date('d/m/Y H:i') }}{% endif %}
                                </p>
                                {% if event.locationName %}
                                    <p class="card-text mb-1"><strong>Lieu :</strong> {{ event.locationName }}</p>
                                {% endif %}

                                <p class="card-text mb-2">
                                    <strong>Statut :</strong>
                                    {% if event.status == 'PUBLISHED' %}
                                        <span class="badge bg-success">{{ event.status }}</span>
                                    {% elseif event.status == 'DRAFT' %}
                                        <span class="badge bg-secondary">{{ event.status }}</span>
                                    {% else %}
                                        <span class="badge bg-danger">{{ event.status }}</span>
                                    {% endif %}
                                </p>

                                {% if event.maxParticipants %}
                                    {% set spots_left = event.spotsLeft() %}
                                    <p class="mb-1"><strong>Places disponibles :</strong> {{ spots_left }}/{{ event.maxParticipants }}</p>
                                    <div class="progress mb-2" style="height: 10px;">
                                        {% set percent = ((event.maxParticipants - spots_left) / event.maxParticipants * 100)|round(0, 'ceil') %}
                                        <div class="progress-bar {% if percent < 50 %}bg-success{% elseif percent < 80 %}bg-warning{% else %}bg-danger{% endif %}"
                                             role="progressbar"
                                             style="width: {{ percent }}%;"
                                             aria-valuenow="{{ percent }}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                {% endif %}

                                <a href="{{ path('app_event_show', {slug: event.slug}) }}" class="btn btn-primary mt-auto">Voir détails</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center"><p class="text-muted">Aucun événement à venir pour le moment.</p></div>
                {% endfor %}
            </div>
        </div>
    </section>

{# Fin Section Events #}


    {# Début Section PartnerLink #}
    <section id="partenaires" class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-4">Nos Partenaires</h2>
            <div class="row justify-content-center">
                {% for partner in partners %}
                    <div class="col-6 col-md-3 text-center mb-4">
                        <a href="{{ partner.url }}" target="_blank" rel="noopener">
                            {% if partner.logo %}
                                <img src="{{ asset(partner.logo) }}" alt="{{ partner.label }}" class="img-fluid" style="max-height: 100px;">
                            {% else %}
                                <span>{{ partner.label }}</span>
                            {% endif %}
                        </a>
                    </div>
                {% else %}
                    <p class="text-center">Aucun partenaire pour le moment.</p>
                {% endfor %}
            </div>
        </div>
    </section>
    {# Fin Section PartnerLink #}


</main>

<footer class="site-footer">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <p class="copyright-text">© 2025 Association des Plaisanciers d'Arzal</p>
            </div>
        </div>
    </div>
</footer>

<!-- JAVASCRIPT FILES -->
<script src="{{ asset('js/jquery.min.js') }}"></script>
<script src="{{ asset('js/bootstrap.min.js') }}"></script>
<script src="{{ asset('js/jquery.sticky.js') }}"></script>
<script src="{{ asset('js/click-scroll.js') }}"></script>
<script src="{{ asset('js/custom.js') }}"></script>

</body>

</html>

{% endblock %}

