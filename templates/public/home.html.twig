        <a href="{{ path('app_login') }}" class="btn custom-btn d-lg-none ms-auto me-4">Mon compte</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav align-items-lg-center ms-auto me-lg-5">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_event_index') }}">Événements</a></li>
{#                <li class="nav-item"><a class="nav-link" href="{{ path('app_association') }}">L'association</a></li>#}
{#                <li class="nav-item"><a class="nav-link" href="{{ path('app_annonces') }}">Annonces</a></li>#}
{#                <li class="nav-item"><a class="nav-link" href="{{ path('app_contact') }}">Contactez-nous</a></li>#}
{#                <li class="nav-item"><a class="nav-link" href="{{ path('app_sortie_mer') }}">Sortie en mer</a></li>#}
{#                <li class="nav-item"><a class="nav-link" href="{{ path('app_navigation') }}">Navigation</a></li>#}
{#                <li class="nav-item"><a class="nav-link" href="{{ path('app_actualites') }}">Actualités</a></li>#}
            </ul>

            <a href="{{ path('app_login') }}" class="btn custom-btn d-lg-block d-none">Mon compte</a>
        </div>
    </div>
</nav>

<main>
    <section class="hero-section" id="section_1">
        <div class="section-overlay"></div>
        <div class="container d-flex justify-content-center align-items-center">
            <div class="row">
                <div class="col-12 mt-auto mb-5 text-center">
                    <small>Association des Plaisanciers d'Arzal</small>
                    <h1 class="text-white mb-5">Bienvenue sur notre site !</h1>
                    <a class="btn custom-btn smoothscroll" href="#section_2">Découvrir</a>
                </div>

                <div class="col-lg-12 col-12 mt-auto d-flex flex-column flex-lg-row text-center">
                    <div class="date-wrap">
                        <h5 class="text-white">
                            <i class="custom-icon bi-clock me-2"></i>
                            Prochain événement : 12 Octobre 2025
                        </h5>
                    </div>

                    <div class="location-wrap mx-auto py-3 py-lg-0">
                        <h5 class="text-white">
                            <i class="custom-icon bi-geo-alt me-2"></i>
                            Port de plaisance d'Arzal dans le Morbihan
                        </h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="video-wrap">
            <video autoplay loop muted class="custom-video" poster="">
                <source src="{{ asset('video/istockphoto-1293944549-640_adpp_is.mp4') }}" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    </section>

    {# Salut Oscar c'est Clément : Ici on ajoutera les sections suivantes "Actualités", etc. #}

    <section id="events-section" class="section-padding bg-light">
        <div class="container">
            <div class="row mb-5">
                <div class="col-12 text-center">
                    <h2 class="mb-3">Prochains événements</h2>
                    <p class="text-muted">Découvrez nos sorties et activités à venir</p>
                </div>
            </div>

            <div class="row">
                {% for event in events %}
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">{{ event.title }}</h5>
                                <p class="card-text mb-1">
                                    <strong>Date :</strong> {{ event.startAt|date('d/m/Y H:i') }}
                                    {% if event.endAt %}
                                        - {{ event.endAt|date('d/m/Y H:i') }}
                                    {% endif %}
                                </p>
                                {% if event.locationName %}
                                    <p class="card-text mb-1"><strong>Lieu :</strong> {{ event.locationName }}</p>
                                {% endif %}

                                <p class="card-text mb-2">
                                    <strong>Statut :</strong>
                                    {% if event.status == 'PUBLISHED' %}
                                        <span class="badge bg-success">{{ event.status }}</span>
                                    {% elseif event.status == 'DRAFT' %}
                                        <span class="badge bg-secondary">{{ event.status }}</span>
                                    {% else %}
                                        <span class="badge bg-danger">{{ event.status }}</span>
                                    {% endif %}
                                </p>

                                {% if event.maxParticipants %}
                                    {% set spots_left = event.spotsLeft() %}
                                    <p class="mb-1"><strong>Places disponibles :</strong> {{ spots_left }}/{{ event.maxParticipants }}</p>
                                    <div class="progress mb-2" style="height: 10px;">
                                        {% set percent = ((event.maxParticipants - spots_left) / event.maxParticipants * 100)|round(0, 'ceil') %}
                                        <div class="progress-bar {% if percent < 50 %}bg-success{% elseif percent < 80 %}bg-warning{% else %}bg-danger{% endif %}"
                                             role="progressbar"
                                             style="width: {{ percent }}%;"
                                             aria-valuenow="{{ percent }}" aria-valuemin="0" aria-valuemax="100">
                                        </div>
                                    </div>
                                {% endif %}

                                <a href="{{ path('app_event_show', {slug: event.slug}) }}" class="btn btn-primary mt-auto">Voir détails</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center">
                        <p class="text-muted">Aucun événement à venir pour le moment.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>


</main>

<footer class="site-footer">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <p class="copyright-text">© 2025 Association des Plaisanciers d'Arzal</p>
            </div>
        </div>
    </div>
</footer>

