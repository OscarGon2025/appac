{% extends 'base.html.twig' %}

{% block title %}Archives{% endblock %}

{% block body %}
    <h1 class="mb-5 text-center">Documents des archives</h1>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            {% if archives is not empty %}
                {% for doc in archives %}
                    <div class="card shadow-sm mb-4">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1">{{ doc.title }}</h5>
                                <small class="text-muted">{{ doc.description }}</small>
                            </div>
                            {% if doc.fileName %}
                                <a href="{{ asset('uploads/documents/' ~ doc.fileName) }}" class="btn btn-primary" target="_blank">
                                    Visualiser / Télécharger
                                </a>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <p class="text-center">Aucun document d’archive disponible pour le moment.</p>
            {% endif %}
        </div>
    </div>
{% endblock %}
