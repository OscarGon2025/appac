{# templates/account/index.html.twig #}
{% extends 'base.html.twig' %}

{% set navbar_is_transparent = false %}
{% block title %}Mon compte{% endblock %}

{% block body %}
    <section id="account" class="section-padding bg-white px-4 py-5 pt-lg-5 mt-5">
        <div class="container">

            <div class="row align-items-end mb-4">
                <div class="col-12 col-lg-8">
                    <h1 class="display-6 fw-bold mb-1">Bienvenue dans votre espace membre</h1>
                    <p class="text-muted mb-0">
                        Gérez vos informations, vos annonces et vos événements depuis cet espace.
                    </p>
                </div>
            </div>

            <div class="row gx-4 gy-4">
                {# ======================
         Mes informations
         ====================== #}
                <div class="col-lg-5">
                    <div class="card shadow-sm border-0 h-100 account-card">
                        <div class="card-header bg-light border-0 py-3">
                            <div class="d-flex align-items-center gap-2">
              <span class="icon-circle text-primary">
                <i class="bi bi-person-circle"></i>
              </span>
                                <div>
                                    <h5 class="mb-0">Mes informations</h5>
                                    <small class="text-muted">Vos coordonnées de compte</small>
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            <dl class="row mb-0 small">
                                <dt class="col-sm-4 text-muted">Email</dt>
                                <dd class="col-sm-8 fw-semibold">{{ app.user.email }}</dd>

                                {% if app.user.firstname is not empty %}
                                    <dt class="col-sm-4 text-muted">Prénom</dt>
                                    <dd class="col-sm-8">{{ app.user.firstname }}</dd>
                                {% endif %}

                                {% if app.user.lastname is not empty %}
                                    <dt class="col-sm-4 text-muted">Nom</dt>
                                    <dd class="col-sm-8">{{ app.user.lastname }}</dd>
                                {% endif %}
                            </dl>
                        </div>

                        <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                            <a href="{{ path('app_account_edit') }}" class="btn btn-outline-primary w-100 account-btn">
                                <i class="bi bi-pencil-square me-2"></i> Modifier mon profil
                            </a>
                        </div>
                    </div>
                </div>

                {# ======================
         Mes actions
         ====================== #}
                <div class="col-lg-7">
                    <div class="card shadow-sm border-0 h-100 account-card">
                        <div class="card-header bg-light border-0 py-3">
                            <div class="d-flex align-items-center gap-2">
              <span class="icon-circle text-primary">
                <i class="bi bi-lightning-charge"></i>
              </span>
                                <div>
                                    <h5 class="mb-0">Mes actions</h5>
                                    <small class="text-muted">Accès rapide aux fonctionnalités</small>
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="row g-3">
                                {# --- Bloc Annonces --- #}
                                <div class="col-12">
                                    <div class="section-block">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="text-uppercase text-muted small fw-semibold">Annonces</span>
                                        </div>

                                        <div class="d-grid gap-2 d-sm-flex">
                                            <a href="{{ path('account_ad_new') }}" class="btn btn-primary flex-fill account-btn">
                                                <i class="bi bi-plus-lg me-2"></i> Déposer une annonce
                                            </a>
                                            <a href="{{ path('account_ad_index') }}" class="btn btn-outline-primary flex-fill account-btn">
                                                <i class="bi bi-megaphone me-2"></i> Mes annonces
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                {# --- Bloc Événements --- #}
                                <div class="col-12">
                                    <div class="section-block">
                                        <span class="text-uppercase text-muted small fw-semibold d-block mb-2">Événements</span>

                                        <div class="d-grid gap-2 d-sm-flex mb-2">
                                            <a href="{{ path('account_events_index') }}" class="btn btn-outline-primary flex-fill account-btn">
                                                <i class="bi bi-calendar3 me-2"></i> Voir mes événements
                                            </a>
                                            <a href="{{ path('account_events_my_outings') }}" class="btn btn-outline-primary flex-fill account-btn">
                                                <i class="bi bi-flag me-2"></i> Mes sorties inscrites
                                            </a>
                                        </div>

                                        <a href="{{ path('account_events_new') }}" class="btn btn-outline-primary w-100 account-btn">
                                            <i class="bi bi-plus-circle me-2"></i> Créer un événement
                                        </a>
                                    </div>
                                </div>

                                {# --- Bloc Administration --- #}
                                {% if is_granted('ROLE_ADMIN') %}
                                    <div class="col-12">
                                        <div class="section-block">
                                            <span class="text-uppercase text-muted small fw-semibold d-block mb-2">Administration</span>
                                            <a href="{{ path('admin') }}" class="btn btn-outline-secondary w-100 account-btn">
                                                <i class="bi bi-speedometer2 me-2"></i> Accéder au back-office
                                            </a>
                                        </div>
                                    </div>
                                {% endif %}

                                {# --- Bloc Sécurité / Session --- #}
                                <div class="col-12">
                                    <div class="section-block">
                                        <span class="text-uppercase text-muted small fw-semibold d-block mb-2">Compte</span>

                                        <div class="d-grid gap-2">
                                            <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary account-btn">
                                                <i class="bi bi-box-arrow-right me-2"></i> Se déconnecter
                                            </a>

                                            <form method="post"
                                                  action="{{ path('app_account_delete') }}"
                                                  onsubmit="return confirm('Cette action est irréversible. Êtes-vous sûr de vouloir supprimer votre compte ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_account' ~ app.user.id) }}">
                                                <button type="submit" class="btn btn-danger w-100 account-btn">
                                                    <i class="bi bi-trash me-2"></i> Supprimer mon compte
                                                </button>
                                                <small class="text-muted d-block mt-1">Action irréversible</small>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section>

    {# CSS léger pour homogénéiser #}
    <style>
        .account-card { border-radius: 14px; }
        .account-btn { padding: .7rem 1rem; border-radius: 12px; }
        .section-block {
            border: 1px solid rgba(0,0,0,.06);
            border-radius: 14px;
            padding: 1rem;
            background: #fff;
        }
        .icon-circle{
            width: 38px; height: 38px;
            display: inline-flex; align-items: center; justify-content: center;
            border-radius: 12px;
            background: rgba(13,110,253,.10); /* basé sur Bootstrap primary */
            font-size: 1.1rem;
        }
        .btn:hover { transform: translateY(-1px); }
    </style>
{% endblock %}
