{# templates/account/index.html.twig (ou mon_compte.html.twig) #}
{% extends 'base.html.twig' %}

{# Sur les pages enfants, la barre de navigation doit être opaque (non transparente) #}
{% set navbar_is_transparent = false %}

{% block title %}Mon compte{% endblock %}

{% block body %}
    <section id="account" class="section-padding bg-white">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <h1 class="display-5 fw-bold mb-4">Bienvenue dans votre espace membre</h1>
                </div>
            </div>

            <div class="row gx-4 gy-4">
                {# Informations utilisateur #}
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                                <i class="bi bi-person-circle"></i> Mes informations
                            </h5>

                            <dl class="row mb-0">
                                <dt class="col-sm-4">Email</dt>
                                <dd class="col-sm-8">{{ app.user.email }}</dd>

                                {% if app.user.firstname is defined %}
                                    <dt class="col-sm-4">Prénom</dt>
                                    <dd class="col-sm-8">{{ app.user.firstname }}</dd>
                                {% endif %}

                                {% if app.user.lastname is defined %}
                                    <dt class="col-sm-4">Nom</dt>
                                    <dd class="col-sm-8">{{ app.user.lastname }}</dd>
                                {% endif %}
                            </dl>
                        </div>
                    </div>
                </div>

                {# Actions #}
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                                <i class="bi bi-lightning-charge"></i> Mes actions
                            </h5>

                            <div class="d-grid gap-2">
                                <a href="{{ path('app_event_index') }}" class="btn btn-outline-dark">
                                    <i class="bi bi-calendar-event me-1"></i> Voir les événements
                                </a>
                                <a href="{{ path('app_event_new') }}" class="btn custom-btn">
                                    <i class="bi bi-plus-circle me-1"></i> Créer un événement
                                </a>
                                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">
                                    <i class="bi bi-box-arrow-right me-1"></i> Se déconnecter
                                </a>
                            </div>

                            {# au cas ou on a besoin "coller" les boutons en bas sur les écrans hauts #}
                            {# <div class="mt-auto"></div> #}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
