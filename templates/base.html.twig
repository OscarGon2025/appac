{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}Site des Plaisanciers{% endblock %}</title>

    {# CSS du thème #}
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap-icons.css') }}" rel="stylesheet">
    <link href="{{ asset('css/templatemo-festava-live.css') }}" rel="stylesheet">
    {# Vos overrides #}
    <link href="{{ asset('css/custom.css') }}" rel="stylesheet">

    {# Polices #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;400;700&display=swap" rel="stylesheet">
</head>

{# Classe optionnelle sur <body> (ex: 'page-login') #}
{% set body_class = body_class|default('') %}

<body class="{{ body_class }}">

{# =========================================================
       BARRE HAUTE (météo / marées / lien écluses)
       - Rendu via un contrôleur : route 'site_header'
       - Apparaît sur toutes les pages
       ========================================================= #}
{{ render(path('site_header')) }}

{# =========================================================
       NAVBAR PRINCIPALE
       - Transparente si la page enfant le demande
         (voir bloc 'navbar_transparent' plus bas)
       - Alternative: forcer un thème sombre pour page-login
       ========================================================= #}
{# --- Options de page injectées par les vues enfants --- #}

{% set navbar_is_transparent = navbar_is_transparent|default(false) %}

<nav class="navbar navbar-expand-lg
    {{ navbar_is_transparent ? 'navbar-transparent' : 'navbar-opaque navbar-dark' }}">
    ...
</nav>

<nav class="navbar navbar-expand-lg festava-navbar
                {{ navbar_is_transparent ? 'is-transparent top-0 start-0 w-100' : '' }}
                {{ body_class == 'page-login' ? 'navbar-dark bg-dark shadow-sm' : '' }}"
                {{ body_class == 'app_event_index' ? 'navbar-dark bg-dark shadow-sm' : '' }}">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">Site des Plaisanciers</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Basculer la navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav align-items-lg-center ms-auto me-lg-5">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#about">Qui sommes-nous ?</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#actus">Actus</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#events-section">Événements</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#partenaires">Partenaires</a></li>
            </ul>

            {# Boutons à droite #}
            {% if app.user %}
                <div class="d-flex gap-2">
                    <a href="{{ path('app_home') }}#actus" class="btn btn-outline-light">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="btn custom-btn">Déconnexion</a>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn custom-btn">Connexion</a>
            {% endif %}
        </div>
    </div>
</nav>

{# =========================================================
       CONTENU DES PAGES ENFANTS
       ========================================================= #}
<main>
    {% block body %}{% endblock %}
</main>

{# =========================================================
       JS (ordre recommandé par le thème)
       ========================================================= #}
<script src="{{ asset('js/jquery.min.js') }}"></script>
<script src="{{ asset('js/bootstrap.min.js') }}"></script>
<script src="{{ asset('js/jquery.sticky.js') }}"></script>
<script src="{{ asset('js/click-scroll.js') }}"></script>
<script src="{{ asset('js/custom.js') }}"></script>

{% block javascripts %}{% endblock %}
</body>
</html>
