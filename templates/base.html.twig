<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}Site des Plaisanciers{% endblock %}</title>

    {# CSS du thème #}
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap-icons.css') }}" rel="stylesheet">
    <link href="{{ asset('css/templatemo-festava-live.css') }}" rel="stylesheet">
    {# Vos overrides #}
    <link href="{{ asset('css/custom.css') }}" rel="stylesheet">

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;400;700&display=swap" rel="stylesheet">

    {% block stylesheets %}{% endblock %}

    <style>html{scroll-behavior:smooth}</style>
</head>

{# body_class pour chaque view: {% set body_class = 'page-login' %} #}
<body class="{{ body_class|default('') }}">

<nav class="navbar navbar-expand-lg {{ body_class == 'page-login' ? 'navbar-dark bg-dark shadow-sm' : '' }}">

    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">
            Site des Plaisanciers
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav align-items-lg-center ms-auto me-lg-5">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                </li>
                <li class="nav-item">

                    <a class="nav-link" href="{{ path('app_home') }}#actus">Actus</a>

                    <a class="nav-link" href="{{ path('app_event_index') }}">Événements</a>

                </li>
{#                <li class="nav-item">#}
{#                    <a class="nav-link" href="{{ path('app_association') }}">L'association</a>#}
{#                </li>#}
{#                <li class="nav-item">#}
{#                    <a class="nav-link" href="{{ path('app_annonces') }}">Annonces</a>#}
{#                </li>#}
{#                <li class="nav-item">#}
{#                    <a class="nav-link" href="{{ path('app_contact') }}">Contactez-nous</a>#}
{#                </li>#}
{#                <li class="nav-item">#}
{#                    <a class="nav-link" href="{{ path('app_sortie') }}">Sortie en mer</a>#}
{#                </li>#}
{#                <li class="nav-item">#}
{#                    <a class="nav-link" href="{{ path('app_navigation') }}">Navigation</a>#}
{#                </li>#}
{#                <li class="nav-item">#}
{#                    <a class="nav-link" href="{{ path('app_actualites') }}">Actualités</a>#}
{#                </li>#}
            </ul>

            <ul class="navbar-nav">
                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_account') }}">
                            Mon compte
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">Se déconnecter</a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">Se connecter</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_register') }}">Créer un compte</a>
                    </li>
                {% endif %}
            </ul>

            {# À droite: Connexion si anonyme; si connecté, Mon compte + Déconnexion #}
            {% if app.user %}
                <div class="d-flex gap-2">
                    <a href="{{ path('app_home') }}#actus" class="btn btn-outline-dark">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="btn custom-btn">Déconnexion</a>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn custom-btn">Connexion</a>
            {% endif %}
        </div>
    </div>
</nav>

<main>
    {% block body %}{% endblock %}
</main>

{# JS du thème #}
<script src="{{ asset('js/jquery.min.js') }}"></script>
<script src="{{ asset('js/bootstrap.min.js') }}"></script>
<script src="{{ asset('js/jquery.sticky.js') }}"></script>
<script src="{{ asset('js/click-scroll.js') }}"></script>
<script src="{{ asset('js/custom.js') }}"></script>

{% block javascripts %}{% endblock %}
</body>
</html>
