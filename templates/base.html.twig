<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}Site des Plaisanciers{% endblock %}</title>

    {# CSS du thème #}
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/bootstrap-icons.css') }}" rel="stylesheet">
    <link href="{{ asset('css/templatemo-festava-live.css') }}" rel="stylesheet">
    <link href="{{ asset('css/custom.css') }}" rel="stylesheet">

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;400;700&display=swap" rel="stylesheet">

    {% block stylesheets %}{% endblock %}

    <style>html{scroll-behavior:smooth}</style>

    {# Google reCAPTCHA v3 #}
    {% if recaptcha_site is defined %}
        <script src="https://www.google.com/recaptcha/api.js?render={{ recaptcha_site }}"></script>
    {% endif %}
</head>

{# Définit body_class si non fourni #}
{% set body_class = body_class|default('') %}
<body class="{{ body_class }}">

<header class="site-header bg-warning py-2">
    <div class="container">
        <div class="row align-items-center g-2">
            <div class="col-12 col-lg d-flex flex-wrap">
                <p class="d-flex me-4 mb-0">
                    <i class="bi-person custom-icon me-2"></i>
                    <strong class="text-dark">Bienvenue sur le site de l’Association des Plaisanciers d’Arzal</strong>
                </p>
            </div>

            <div class="col-12 col-lg-auto text-dark small">
                {% if header.weather is defined %}
                    <span class="me-3"><i class="bi bi-thermometer-half"></i> {{ header.weather.temp }}°C, {{ header.weather.desc }}</span>
                    <span class="me-3"><i class="bi bi-wind"></i> {{ header.weather.wind }} km/h</span>
                {% endif %}
                {% if header.tide is defined %}
                    <span class="me-3"><i class="bi bi-water"></i> Prochaine marée : {{ header.tide.nextType }} à {{ header.tide.nextTime|date('H:i') }}</span>
                {% endif %}
            </div>
        </div>
    </div>
</header>

<nav class="navbar navbar-expand-lg {{ body_class == 'page-login' ? 'navbar-dark bg-dark shadow-sm' : '' }}">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">Site des Plaisanciers</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav align-items-lg-center ms-auto me-lg-5">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#about">Qui sommes-nous ?</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#actus">Actus</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}#events-section">Événements</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">Créer un compte</a></li>
            </ul>

            {% if app.user %}
                <div class="d-flex gap-2">
                    <a href="{{ path('app_home') }}#actus" class="btn btn-outline-light">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="btn custom-btn">Déconnexion</a>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn custom-btn">Connexion</a>
            {% endif %}
        </div>
    </div>
</nav>

<main>
    {% block body %}{% endblock %}
</main>

{# JS du thème #}
<script src="{{ asset('js/jquery.min.js') }}"></script>
<script src="{{ asset('js/bootstrap.min.js') }}"></script>
<script src="{{ asset('js/jquery.sticky.js') }}"></script>
<script src="{{ asset('js/click-scroll.js') }}"></script>
<script src="{{ asset('js/custom.js') }}"></script>

{% block javascripts %}{% endblock %}

{# reCAPTCHA v3 injection pour tous les formulaires #}
{% if recaptcha_site is defined %}
    <script>
        grecaptcha.ready(function() {
            document.querySelectorAll('form').forEach(function(form) {
                form.addEventListener('submit', function(e) {
                    grecaptcha.execute('{{ recaptcha_site }}', {action: 'register'}).then(function(token) {
                        let input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'g-recaptcha-response';
                        input.value = token;
                        form.appendChild(input);
                        form.submit();
                    });
                    e.preventDefault();
                });
            });
        });
    </script>
{% endif %}

</body>
</html>

