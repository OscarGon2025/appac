{% extends 'base.html.twig' %}
{% block title %}Nouvel événement{% endblock %}

{# Usa el theme Bootstrap 5 y aplica nuestras clases #}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block body %}
    <section class="container-lg px-4 py-5 page-under-navbar" id="event-new" aria-labelledby="event-new-title">
        <nav aria-label="Fil d’Ariane" class="mb-3">
            <ol class="breadcrumb bg-transparent px-0 mb-0">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_event_index') }}" class="text-decoration-none">Événements</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Créer</li>
            </ol>
        </nav>

        <header class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-4">
            <div>
                <h1 id="event-new-title" class="display-6 fw-bold mb-1">Créer un nouvel événement</h1>
                <p class="text-muted mb-0">Renseignez les infos principales puis publiez quand tout est prêt.</p>
            </div>
            <a href="{{ path('app_event_index') }}" class="btn btn-outline-dark">
                <i class="bi bi-chevron-left me-1"></i>Retour à la liste
            </a>
        </header>

        {{ form_start(form, {attr: {class: 'needs-validation', novalidate: 'novalidate'}}) }}

        <div class="row g-4">
            <div class="col-lg-8">
                {# --- Informations --- #}
                <div class="card card-pane shadow-sm mb-3">
                    <div class="card-header bg-white border-0 px-4 pt-4">
                        <h2 class="h5 fw-semibold mb-0">Informations</h2>
                    </div>
                    <div class="card-body px-4 pb-4">

                        <div class="mb-3">
                            {{ form_label(form.title, 'Titre de l’événement', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                            {{ form_widget(form.title, {'attr': {'class':'form-control form-control-lg', 'placeholder':'Ex. Sortie conviviale vers Pénestin'}}) }}
                            {{ form_errors(form.title) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.description, 'Description', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                            {{ form_widget(form.description, {'attr': {'class':'form-control', 'rows':6, 'placeholder':'Détails, matériel, conditions, etc.'}}) }}
                            <div class="form-text">Quelques lignes pour présenter l’activité.</div>
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="mb-0">
                            {{ form_label(form.type, 'Type', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-compass"></i></span>
                                {{ form_widget(form.type, {'attr': {'class':'form-select'}}) }}
                            </div>
                            {{ form_errors(form.type) }}
                        </div>

                    </div>
                </div>

                {# --- Planning --- #}
                <div class="card card-pane shadow-sm mb-3">
                    <div class="card-header bg-white border-0 px-4 pt-4">
                        <h2 class="h5 fw-semibold mb-0">Planning</h2>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_label(form.startAt, 'Date de début', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                                    {{ form_widget(form.startAt, {'attr': {'class':'form-control', 'placeholder':'jj/mm/aaaa --:--'}}) }}
                                </div>
                                {{ form_errors(form.startAt) }}
                                <div class="form-text">Début (date & heure).</div>
                            </div>

                            <div class="col-md-6">
                                {{ form_label(form.endAt, 'Date de fin', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-calendar2-week"></i></span>
                                    {{ form_widget(form.endAt, {'attr': {'class':'form-control', 'placeholder':'jj/mm/aaaa --:--'}}) }}
                                </div>
                                {{ form_errors(form.endAt) }}
                                <div class="form-text">Facultatif si non pertinent.</div>
                            </div>
                        </div>

                        <div class="mt-3">
                            {{ form_label(form.locationName, 'Lieu', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
                                {{ form_widget(form.locationName, {'attr': {'class':'form-control', 'placeholder':'Capitainerie d’Arzal-Camoël…'}}) }}
                            </div>
                            {{ form_errors(form.locationName) }}
                        </div>
                    </div>
                </div>

                {# --- Capacité & Accès --- #}
                <div class="card card-pane shadow-sm">
                    <div class="card-header bg-white border-0 px-4 pt-4">
                        <h2 class="h5 fw-semibold mb-0">Capacité & Accès</h2>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_label(form.maxParticipants, 'Nombre maximum de participants', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.maxParticipants, {'attr': {'class':'form-control', 'min':0, 'placeholder':'Illimité'}}) }}
                                    <span class="input-group-text">places</span>
                                </div>
                                <div class="form-text">Laissez vide si illimité.</div>
                                {{ form_errors(form.maxParticipants) }}
                            </div>

                            <div class="col-md-6 d-flex align-items-center">
                                <div class="form-check form-switch form-switch-lg ms-2">
                                    {{ form_widget(form.registrationOpen, {'attr': {'class':'form-check-input'}}) }}
                                    {{ form_label(form.registrationOpen, 'Inscriptions ouvertes', {'label_attr': {'class':'form-check-label ms-2'}}) }}
                                    {{ form_errors(form.registrationOpen) }}
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                {{ form_label(form.status, 'Statut', {'label_attr': {'class':'form-label fw-semibold'}}) }}
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-flag"></i></span>
                                    {{ form_widget(form.status, {'attr': {'class':'form-select'}}) }}
                                </div>
                                <div class="form-text">Brouillon, Publié, etc.</div>
                                {{ form_errors(form.status) }}
                            </div>

                            {% if form.isMembersOnly is defined %}
                                <div class="col-md-6 d-flex align-items-center">
                                    <div class="form-check form-switch form-switch-lg ms-2">
                                        {{ form_widget(form.isMembersOnly, {'attr': {'class':'form-check-input'}}) }}
                                        {{ form_label(form.isMembersOnly, 'Réservé aux membres', {'label_attr': {'class':'form-check-label ms-2'}}) }}
                                        {{ form_errors(form.isMembersOnly) }}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-primary" data-prevent-dbl>
                        <i class="bi bi-check2-circle me-1"></i>Créer
                    </button>
                    <a href="{{ path('app_event_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </div>

            {# Colonne d’aide #}
            <aside class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top: 6rem;">
                    <div class="card-body">
                        <h2 class="h6 text-uppercase text-muted mb-3">Conseils</h2>
                        <ul class="small ps-3 mb-0">
                            <li>Titre <strong>clair</strong> et précis.</li>
                            <li><strong>Dates</strong> exactes (début/fin).</li>
                            <li><strong>Lieu</strong> et <strong>description</strong> courte.</li>
                            <li><strong>Nombre de places</strong> si pertinent.</li>
                        </ul>
                    </div>
                </div>
            </aside>
        </div>

        {{ form_end(form) }}
    </section>

    <script>
        // double envoi eviter conflits avec bootstrap
        (function () {
            document.querySelectorAll('button[data-prevent-dbl]').forEach(btn => {
                btn.addEventListener('click', () => {
                    if (btn.dataset.locked) return;
                    btn.dataset.locked = '1';
                    setTimeout(() => { delete btn.dataset.locked; }, 2500);
                });
            });
            const form = document.querySelector('form.needs-validation');
            if (!form) return;
            form.addEventListener('submit', function (e) {
                if (!form.checkValidity()) { e.preventDefault(); e.stopPropagation(); }
                form.classList.add('was-validated');
            }, false);
        })();
    </script>
{% endblock %}
