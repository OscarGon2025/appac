{% extends 'base.html.twig' %}

{# La barra NO debe ser transparente aquí #}
{% set navbar_is_transparent = false %}

{% block title %}Événements{% endblock %}


{% block body %}
    <section class="section-padding" id="events-list">
        <div class="container">
            <div class="row mb-5">
                <div class="col-12 text-center">
                    <h2 class="mb-3">Prochains événements</h2>
                    <p class="text-muted">Découvrez nos sorties et activités à venir</p>
                </div>
            </div>

            {% if events is empty %}
                <div class="row">
                    <div class="col-12 text-center">
                        <p class="text-muted">Aucun événement publié pour le moment.</p>
                    </div>
                </div>
            {% else %}
                <div class="row">
                    {% for event in events %}
                        <div class="col-xl-4 col-lg-4 col-md-6 mb-4">
                            <article class="custom-block-wrap h-100">

                                {# --- Fondo neutro con icono (no usamos event.cover) --- #}
                                <div class="custom-block-image d-flex align-items-center justify-content-center"
                                     style="aspect-ratio: 16/9; background:#eef2f6;">
                                    {# Puedes variar el icono según el tipo #}
                                    {% set typeIcon =
                                        event.type == 'REGATTA' ? 'bi-flag' :
                                        event.type == 'MEETING' ? 'bi-people' :
                                        event.type == 'OUTING'  ? 'bi-compass' : 'bi-calendar-event' %}
                                    <i class="bi {{ typeIcon }}" style="font-size:2rem; color:#94a3b8;"></i>
                                </div>

                                <div class="custom-block d-flex flex-column">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        {% if event.status == 'PUBLISHED' %}
                                            <span class="badge bg-success">Publié</span>
                                        {% elseif event.status == 'DRAFT' %}
                                            <span class="badge bg-secondary">Brouillon</span>
                                        {% elseif event.status == 'CANCELLED' %}
                                            <span class="badge bg-danger">Annulé</span>
                                        {% endif %}

                                        {% if event.isMembersOnly %}
                                            <span class="badge text-bg-secondary">Membres</span>
                                        {% endif %}
                                    </div>

                                    <h3 class="h5 mb-2">
                                        <a href="{{ path('app_event_show', {'slug': event.slug}) }}" class="custom-btn">
                                            {{ event.title }}
                                        </a>
                                    </h3>

                                    <p class="text-muted mb-2">
                                        <i class="bi bi-calendar-event me-1"></i>
                                        {{ event.startAt|date('d/m/Y H:i') }}
                                        {% if event.endAt %} – {{ event.endAt|date('d/m/Y H:i') }}{% endif %}
                                    </p>

                                    {% if event.locationName %}
                                        <p class="text-muted mb-2">
                                            <i class="bi bi-geo-alt me-1"></i>{{ event.locationName }}
                                        </p>
                                    {% endif %}

                                    {% if event.description %}
                                        {% set excerpt = event.description|striptags %}
                                        <p class="mb-3">{{ excerpt|length > 160 ? excerpt|slice(0,160) ~ '…' : excerpt }}</p>
                                    {% endif %}

                                    {% if event.maxParticipants %}
                                        {% set left = event.spotsLeft() is defined ? event.spotsLeft() : event.maxParticipants %}
                                        {% set used = event.maxParticipants - left %}
                                        {% set percent = (event.maxParticipants > 0) ? ((used / event.maxParticipants * 100)|round(0,'ceil')) : 0 %}
                                        <p class="mb-1"><strong>Places :</strong> {{ used }}/{{ event.maxParticipants }}</p>
                                        <div class="progress mb-3" style="height: 8px;">
                                            <div class="progress-bar
                                {% if percent < 50 %}bg-success
                                {% elseif percent < 80 %}bg-warning
                                {% else %}bg-danger{% endif %}"
                                                 role="progressbar"
                                                 style="width: {{ percent }}%;"
                                                 aria-valuenow="{{ percent }}" aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                    {% endif %}

                                    <div class="mt-auto">
                                        <a href="{{ path('app_event_show', {'slug': event.slug}) }}" class="btn custom-btn">
                                            Voir le détail
                                        </a>
                                    </div>
                                </div>
                            </article>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {# Bouton admin/opcional #}
            <div class="text-center mt-4">
                <a href="{{ path('app_event_new') }}" class="btn btn-success">Créer un nouvel événement</a>
            </div>
        </div>
    </section>
{% endblock %}
