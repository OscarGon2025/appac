
{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
    <section class="container py-5">
        <h1 class="mb-4">Prochains événements</h1>

        {% if events is empty %}
            <p>Aucun événement publié pour le moment.</p>
        {% else %}
            <div class="row">
                {% for event in events %}
                    <div class="col-md-6 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">{{ event.title }}</h5>
                                <p class="card-text">
                                    {{ event.description|length > 100 ? event.description|slice(0, 100) ~ '…' : event.description }}
                                </p>
                                <p class="mb-1"><strong>Type :</strong> {{ event.type }}</p>
                                <p class="mb-1"><strong>Statut :</strong> {{ event.status }}</p>
                                <p class="mb-1">
                                    <strong>Participants :</strong>
                                    {% if event.maxParticipants %}
                                        {{ event.maxParticipants - event.spotsLeft() }}/{{ event.maxParticipants }}
                                    {% else %}
                                        Illimité
                                    {% endif %}
                                </p>
                                <p class="mb-1"><strong>Date :</strong> {{ event.startAt|date('d/m/Y H:i') }}</p>
                                <a href="{{ path('app_event_show', {'slug': event.slug}) }}" class="btn btn-primary mt-2">Voir le détail</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <a href="{{ path('app_event_new') }}" class="btn btn-success mt-4">Créer un nouvel événement</a>
    </section>
{% endblock %}
