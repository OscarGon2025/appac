{% extends 'base.html.twig' %}
{% block title %}Actus{% endblock %}

{% block body %}
    <section class="container py-4">
        <h1 class="mb-4">Derniers articles</h1>

        <div class="row g-4">
            {% for a in articles %}
                <div class="col-md-4">
                    <article class="card h-100">
                        {% if a.cover %}
                            <img src="{{ asset('uploads/covers/' ~ a.cover) }}" class="card-img-top" alt="{{ a.title }}">
                        {% endif %}
                        <div class="card-body d-flex flex-column">
                            <h2 class="h5 card-title">
                                <a href="{{ path('actus_show', { slug: a.slug }) }}">{{ a.title }}</a>
                                {% if a.pinned %}<span class="badge text-bg-warning ms-1">À la une</span>{% endif %}
                                {% if a.isMembersOnly %}<span class="badge text-bg-secondary ms-1">Membres</span>{% endif %}
                            </h2>
                            <p class="text-muted mb-2">{{ a.publishedAt ? a.publishedAt|date('d/m/Y H:i') : '' }}</p>
                            <p class="card-text">{{ a.content|striptags|u.truncate(160, '…') }}</p>
                            <div class="mt-auto">
                                <a class="btn btn-primary btn-sm" href="{{ path('actus_show', { slug: a.slug }) }}">Lire</a>
                            </div>
                        </div>
                    </article>
                </div>
            {% else %}
                <p>Aucun article pour le moment.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}
